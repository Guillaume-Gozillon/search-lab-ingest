ES_URL=http://localhost:9200
ES_INDEX=amazon_products
ES_ALIAS=products
ES_EMBEDDINGS_ALIAS=products_embeddings

# Réplicas rétablis en fin d'import. 0 pour le lab mono-nœud : un réplica y resterait
# non assigné et laisserait l'index en yellow. Monter à 1 sur un vrai cluster.
ES_REPLICAS=0

# Heap Elasticsearch. Le conteneur est plafonné à 12g dans le compose — laisser de la
# marge au-dessus du heap pour le page cache des fichiers Lucene mmapés.
ES_HEAP=6g

# --- Embedding ---------------------------------------------------------------

# Moteur : `tei` (défaut) ou `ollama`. ATTENTION — les deux servent nomic-embed-text-v1.5
# mais ne produisent PAS les mêmes vecteurs : cosinus moyen mesuré à 0,51 sur 1000 titres.
# Changer cette valeur impose de reconstruire l'index : un index bâti avec l'un ne
# s'interroge pas avec l'autre, et rien ne lèvera d'erreur si tu les mélanges.
EMBED_BACKEND=tei

TEI_URL=http://localhost:8080

# Moteur historique. Démarré uniquement avec `make start OLLAMA=1`, gardé pour relire les
# index construits avant la bascule et pour `make compare`.
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMS=768

# Requêtes servies en parallèle par Ollama. À 1 il sérialise tout, quel que soit
# EMBED_WORKERS côté client.
OLLAMA_NUM_PARALLEL=4

# Requêtes d'embedding en vol côté pipeline.
EMBED_WORKERS=4

# Préfixes de tâche nomic. LES LAISSER VIDES sauf décision explicite : les activer change
# les vecteurs (cos entre titre brut et titre préfixé = 0,684), donc impose de
# reconstruire l'index ET d'appliquer EMBED_QUERY_PREFIX côté recherche. L'un sans
# l'autre dégrade la pertinence sans lever la moindre erreur.
EMBED_DOC_PREFIX=
EMBED_QUERY_PREFIX=
