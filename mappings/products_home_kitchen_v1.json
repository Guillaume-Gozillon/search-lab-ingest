{
  "settings": {
    "number_of_shards": 2,
    "number_of_replicas": 0,
    "refresh_interval": "30s"
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "asin": { "type": "keyword" },
      "parent_asin": { "type": "keyword" },
      "title": {
        "type": "text",
        "analyzer": "english",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 512
          }
        }
      },
      "description": { "type": "text", "analyzer": "english" },
      "features": { "type": "text", "analyzer": "english" },
      "main_category": { "type": "keyword" },
      "categories": { "type": "keyword" },
      "store": { "type": "keyword" },
      "price": { "type": "float" },
      "average_rating": { "type": "float" },
      "rating_number": { "type": "integer" },
      "details": { "type": "object", "dynamic": true },
      "has_description": { "type": "boolean" },
      "has_price": { "type": "boolean" },
      "ingested_at": { "type": "date" }
    }
  }
}
